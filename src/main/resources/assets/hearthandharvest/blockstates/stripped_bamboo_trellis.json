{
  "multipart": [
    { "when": { "has_middle": "true", "north": "false", "south": "false", "east": "false", "west": "false", "facing": "north" },
      "apply": { "model": "hearthandharvest:block/stripped_bamboo_trellis" } },
    { "when": { "has_middle": "true", "north": "false", "south": "false", "east": "false", "west": "false", "facing": "south" },
      "apply": { "model": "hearthandharvest:block/stripped_bamboo_trellis", "y": 180 } },
    { "when": { "has_middle": "true", "north": "false", "south": "false", "east": "false", "west": "false", "facing": "east" },
      "apply": { "model": "hearthandharvest:block/stripped_bamboo_trellis", "y": 90 } },
    { "when": { "has_middle": "true", "north": "false", "south": "false", "east": "false", "west": "false", "facing": "west" },
      "apply": { "model": "hearthandharvest:block/stripped_bamboo_trellis", "y": 270 } },
    { "when": { "OR": [
      { "has_middle": "true", "east": "true", "north": "false", "south": "false" },
      { "has_middle": "true", "west": "true", "north": "false", "south": "false" }
    ]},
      "apply": { "model": "hearthandharvest:block/stripped_bamboo_trellis" } },
    { "when": { "OR": [
      { "has_middle": "true", "north": "true", "east": "false", "west": "false" },
      { "has_middle": "true", "south": "true", "east": "false", "west": "false" }
    ]},
      "apply": { "model": "hearthandharvest:block/stripped_bamboo_trellis", "y": 90 } },
    { "when": { "OR": [
      { "has_middle": "true", "north": "true", "east": "true" },
      { "has_middle": "true", "north": "true", "west": "true" },
      { "has_middle": "true", "south": "true", "east": "true" },
      { "has_middle": "true", "south": "true", "west": "true" }
    ]},
      "apply": { "model": "hearthandharvest:block/stripped_bamboo_trellis_cross" } },

    { "when": { "side_north": "true", "has_top": "false", "has_flat": "false" },
      "apply": { "model": "hearthandharvest:block/stripped_bamboo_trellis_side" } },
    { "when": { "side_south": "true", "has_top": "false", "has_flat": "false" },
      "apply": { "model": "hearthandharvest:block/stripped_bamboo_trellis_side", "y": 180 } },
    { "when": { "side_east": "true",  "has_top": "false", "has_flat": "false" },
      "apply": { "model": "hearthandharvest:block/stripped_bamboo_trellis_side", "y": 90 } },
    { "when": { "side_west": "true",  "has_top": "false", "has_flat": "false" },
      "apply": { "model": "hearthandharvest:block/stripped_bamboo_trellis_side", "y": 270 } },

    { "when": { "side_north": "true", "has_top": "true", "has_flat": "false" },
      "apply": { "model": "hearthandharvest:block/stripped_bamboo_trellis_short_top_side" } },
    { "when": { "side_south": "true", "has_top": "true", "has_flat": "false" },
      "apply": { "model": "hearthandharvest:block/stripped_bamboo_trellis_short_top_side", "y": 180 } },
    { "when": { "side_east": "true",  "has_top": "true", "has_flat": "false" },
      "apply": { "model": "hearthandharvest:block/stripped_bamboo_trellis_short_top_side", "y": 90 } },
    { "when": { "side_west": "true",  "has_top": "true", "has_flat": "false" },
      "apply": { "model": "hearthandharvest:block/stripped_bamboo_trellis_short_top_side", "y": 270 } },

    { "when": { "side_north": "true", "has_top": "false", "has_flat": "true" },
      "apply": { "model": "hearthandharvest:block/stripped_bamboo_trellis_short_bottom_side" } },
    { "when": { "side_south": "true", "has_top": "false", "has_flat": "true" },
      "apply": { "model": "hearthandharvest:block/stripped_bamboo_trellis_short_bottom_side", "y": 180 } },
    { "when": { "side_east": "true",  "has_top": "false", "has_flat": "true" },
      "apply": { "model": "hearthandharvest:block/stripped_bamboo_trellis_short_bottom_side", "y": 90 } },
    { "when": { "side_west": "true",  "has_top": "false", "has_flat": "true" },
      "apply": { "model": "hearthandharvest:block/stripped_bamboo_trellis_short_bottom_side", "y": 270 } },

    { "when": { "side_north": "true", "has_top": "true", "has_flat": "true" },
      "apply": { "model": "hearthandharvest:block/stripped_bamboo_trellis_short_both_side" } },
    { "when": { "side_south": "true", "has_top": "true", "has_flat": "true" },
      "apply": { "model": "hearthandharvest:block/stripped_bamboo_trellis_short_both_side", "y": 180 } },
    { "when": { "side_east": "true",  "has_top": "true", "has_flat": "true" },
      "apply": { "model": "hearthandharvest:block/stripped_bamboo_trellis_short_both_side", "y": 90 } },
    { "when": { "side_west": "true",  "has_top": "true", "has_flat": "true" },
      "apply": { "model": "hearthandharvest:block/stripped_bamboo_trellis_short_both_side", "y": 270 } },

    { "when": { "has_flat": "true" },
      "apply": { "model": "hearthandharvest:block/stripped_bamboo_trellis_flat" } },
    { "when": { "has_top": "true" },
      "apply": { "model": "hearthandharvest:block/stripped_bamboo_trellis_top" } }
  ]
}